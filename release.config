#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────
# release.config — Edit this once per project
# ─────────────────────────────────────────────────────────

# ── App identity ──────────────────────────────────────────
APP_NAME="My Awesome App"
ANDROID_PACKAGE="com.example.myapp"
IOS_BUNDLE_ID="com.example.myapp"

# ── Build settings ────────────────────────────────────────
# "apk" or "appbundle" (appbundle recommended for Play Store)
ANDROID_BUILD_TYPE="appbundle"

# Extra flags passed to `flutter build` (e.g. --flavor prod)
FLUTTER_BUILD_FLAGS=""

# ── What's New file ───────────────────────────────────────
# Path to your changelog markdown file (the <lang>...</lang> format).
# The script reads the current version from pubspec.yaml, finds
# the matching entry in this file, and extracts per-language text.
# If a version has no text for a language, it walks backwards to
# find the most recent entry for that language.
WHATS_NEW_FILE="app-whats-new.md"

# Language tags used in your What's New file → store locale codes.
# Format: "file_tag:play_store_locale:app_store_locale"
# The script reads <file_tag>...</file_tag> blocks from the file
# and maps them to the correct store locale for upload.
LANGUAGE_MAP=(
  "uk:uk:uk"
  "en-US:en-US:en-US"
  "ru-RU:ru-RU:ru"
)

# ── Paths ─────────────────────────────────────────────────
PUBSPEC="pubspec.yaml"

# ── Android / Google Play ─────────────────────────────────
# Path to your Google Play service account JSON key.
PLAY_STORE_KEY="keys/play-store-key.json"

# Release track: "internal", "alpha", "beta", or "production"
PLAY_STORE_TRACK="production"

# ── iOS / App Store ───────────────────────────────────────
# App Store Connect API key (recommended over password auth).
ASC_KEY_ID=""
ASC_ISSUER_ID=""
ASC_KEY_FILE="keys/AuthKey.p8"

# ── Git tagging ───────────────────────────────────────────
GIT_TAG_RELEASES=true
GIT_PUSH_TAG=true
